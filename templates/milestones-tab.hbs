<section class="player-milestones-tab-content">
  <h3>Personal Milestones</h3>

  <div class="player-milestones-tab__progress" data-milestones-progress="true">
    <div class="player-milestones-tab__progress-main">
      <span
        class="player-milestones-tab__progress-fraction"
        aria-label="Current milestone progress: {{progress.current}} / {{progress.targetCost}}"
      >
        {{#if progress.canEditCurrent}}
          <input
            type="number"
            min="0"
            step="1"
            value="{{progress.current}}"
            data-progress-current-input="true"
            aria-label="Current milestone progress"
          />
        {{else}}
          <strong>{{progress.current}}</strong>
        {{/if}}
        / <strong>{{progress.targetCost}}</strong>
      </span>

      <div class="player-milestones-tab__progress-actions">
        {{#if progress.isReady}}
          <p class="player-milestones-tab__progress-ready">Ready to level up</p>
        {{/if}}

        <button
          type="button"
          class="player-milestones-tab__button"
          data-action="level-up"
          {{#unless progress.canLevelUp}}disabled{{/unless}}
        >
          Level up
        </button>
      </div>
    </div>
  </div>

  {{#if topMatterHtml}}
    <div class="player-milestones-tab__top-matter">
      {{{topMatterHtml}}}
    </div>
  {{/if}}

  {{#if hasSections}}
    <div class="player-milestones-tab__sections">
      {{#each sections}}
        <details
          class="player-milestones-tab__section"
          data-section-id="{{id}}"
          open
        >
          <summary class="player-milestones-tab__section-header">
            <h3>{{name}}</h3>
          </summary>

          <div class="player-milestones-tab__section-body">
            {{#if hasItems}}
              <div class="player-milestones-tab__items">
              {{#each items}}
                {{#if isCustom}}
                  {{#if ../canManageCustomItems}}
                    <div
                      class="player-milestones-tab__item player-milestones-tab__item--custom"
                      data-custom-item-row="true"
                      data-section-id="{{../id}}"
                      data-item-id="{{id}}"
                      data-editing="false"
                    >
                      <div class="player-milestones-tab__custom-display">
                        <label class="player-milestones-tab__item {{#if checked}}player-milestones-tab__item--checked{{/if}}">
                          <input
                            type="checkbox"
                            data-milestone-checkbox="true"
                            data-section-id="{{../id}}"
                            data-item-id="{{id}}"
                            data-custom-item="true"
                            {{#if checked}}checked{{/if}}
                            {{#unless ../canToggleMilestones}}disabled{{/unless}}
                          />
                          <span class="player-milestones-tab__item-copy">
                            <strong>{{label}}</strong>
                            {{#if description}}
                              <small class="player-milestones-tab__description">{{description}}</small>
                            {{/if}}
                          </span>
                        </label>
                        <div class="player-milestones-tab__item-actions">
                          <button
                            type="button"
                            class="player-milestones-tab__icon-button"
                            data-action="edit-custom-item"
                            title="Edit custom item"
                            aria-label="Edit custom item"
                          >
                            <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
                          </button>
                          <button
                            type="button"
                            class="player-milestones-tab__icon-button player-milestones-tab__button--danger"
                            data-action="remove-custom-item"
                            title="Remove custom item"
                            aria-label="Remove custom item"
                          >
                            <i class="fa-solid fa-trash" aria-hidden="true"></i>
                          </button>
                        </div>
                      </div>

                      <div class="player-milestones-tab__custom-editor">
                        <label class="player-milestones-tab__checkbox-label">
                          <input
                            type="checkbox"
                            data-milestone-checkbox="true"
                            data-section-id="{{../id}}"
                            data-item-id="{{id}}"
                            data-custom-item="true"
                            {{#if checked}}checked{{/if}}
                            {{#unless ../canToggleMilestones}}disabled{{/unless}}
                          />
                        </label>
                        <div class="player-milestones-tab__custom-fields">
                          <input
                            type="text"
                            value="{{label}}"
                            data-custom-title-input="true"
                            data-enter-action="save-custom-item"
                            placeholder="Custom title"
                          />
                          <input
                            type="text"
                            value="{{description}}"
                            data-custom-description-input="true"
                            data-enter-action="save-custom-item"
                            placeholder="Custom description"
                          />
                        </div>
                        <div class="player-milestones-tab__item-actions">
                          <button
                            type="button"
                            class="player-milestones-tab__icon-button"
                            data-action="save-custom-item"
                            title="Save custom item"
                            aria-label="Save custom item"
                          >
                            <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                          </button>
                          <button
                            type="button"
                            class="player-milestones-tab__icon-button"
                            data-action="cancel-custom-item"
                            title="Cancel edit"
                            aria-label="Cancel edit"
                          >
                            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                          </button>
                        </div>
                      </div>
                    </div>
                  {{else}}
                    <label class="player-milestones-tab__item {{#if checked}}player-milestones-tab__item--checked{{/if}}">
                      <input
                        type="checkbox"
                        data-milestone-checkbox="true"
                        data-section-id="{{../id}}"
                        data-item-id="{{id}}"
                        data-custom-item="true"
                        {{#if checked}}checked{{/if}}
                        {{#unless ../canToggleMilestones}}disabled{{/unless}}
                      />
                      <span class="player-milestones-tab__item-copy">
                        <strong>{{label}}</strong>
                      </span>
                    </label>
                  {{/if}}
                {{else}}
                  <label class="player-milestones-tab__item {{#if checked}}player-milestones-tab__item--checked{{/if}}">
                    <input
                      type="checkbox"
                      data-milestone-checkbox="true"
                      data-section-id="{{../id}}"
                      data-item-id="{{id}}"
                      data-custom-item="false"
                      {{#if checked}}checked{{/if}}
                      {{#unless ../canToggleMilestones}}disabled{{/unless}}
                    />
                    <span class="player-milestones-tab__item-copy">
                      <strong>{{label}}</strong>
                      {{#if description}}
                        <small class="player-milestones-tab__description">{{description}}</small>
                      {{/if}}
                    </span>
                  </label>
                {{/if}}
              {{/each}}
            </div>
          {{else}}
            <p class="player-milestones-empty-state">No milestones are defined for this section yet.</p>
          {{/if}}

            {{#if canManageCustomItems}}
              <div class="player-milestones-tab__custom-add" data-custom-add-row="true" data-section-id="{{id}}">
                <div class="player-milestones-tab__custom-fields">
                  <input
                    type="text"
                    data-custom-add-title-input="true"
                    data-enter-action="add-custom-item"
                    placeholder="Custom title"
                  />
                  <input
                    type="text"
                    data-custom-add-description-input="true"
                    data-enter-action="add-custom-item"
                    placeholder="Custom description"
                  />
                </div>
                <button
                  type="button"
                  class="player-milestones-tab__icon-button"
                  data-action="add-custom-item"
                  title="Add custom item"
                  aria-label="Add custom item"
                >
                  <i class="fa-solid fa-plus" aria-hidden="true"></i>
                </button>
              </div>
            {{/if}}
          </div>
        </details>
      {{/each}}
    </div>
  {{else}}
    <p class="player-milestones-empty-state">No shared milestone sections are configured yet.</p>
  {{/if}}
</section>
