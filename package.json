{
  "name": "player-milestones",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "description": "Personal Foundry VTT milestone scaffolding for dnd5e.",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "audit": "npm audit",
    "link:foundry": "node ./scripts/link-foundry.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@league-of-foundry-developers/foundry-vtt-types": "^13.346.0-beta.20250812191140",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1",
    "vite": "^8.0.3",
    "vitest": "^3.2.4"
  }
}
